{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/youtube-edge",
      "destination": "/api/youtube-edge"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/[...route].js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/youtube-edge.js": {
      "maxDuration": 25
    },
    "api/**/*.js": {
      "includeFiles": "backend/src/{routes,middleware,db,utils}/**",
      "excludeFiles": "{node_modules/@hocuspocus,node_modules/@xenova,node_modules/better-sqlite3,node_modules/fluent-ffmpeg,node_modules/@ffmpeg,node_modules/onnxruntime-node,node_modules/sharp,node_modules/canvas}/**"
    }
  },
  "outputDirectory": "dist"
}