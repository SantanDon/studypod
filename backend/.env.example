# Backend Server Configuration
PORT=3001

# CORS Configuration
# The frontend URL that is allowed to make requests to this backend
CORS_ORIGIN=http://localhost:5173

# JWT Configuration
# A strong, random string used to sign authentication tokens.
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-that-is-at-least-32-characters-long

# EverMemOS Configuration
# The base URL for your EverMemOS instance (e.g., http://localhost:8080 or cloud endpoint)
EVERMEMOS_API_URL=http://localhost:8080
# Your EverMemOS API Key
EVERMEMOS_API_KEY=your_evermemos_api_key_here

