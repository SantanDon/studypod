# StudyPodLM API configuration
# Copy this to .env and fill in your values

# Your StudyPodLM backend URL (local or production)
STUDYPODLM_API_URL=http://localhost:3001

# Your JWT token - get this from localStorage after logging in:
# Open devtools > Console > type: localStorage.getItem('auth_token')
STUDYPODLM_TOKEN=your_jwt_token_here
